{
  "$schema": "cullis-test-vectors-v1",
  "primitive": "signed_canonical",
  "warning": "DO NOT USE THESE KEYS IN PRODUCTION \u2014 test vectors only",
  "header": "Canonical bytes signed by RSA-PSS / ECDSA in Cullis message_signer.py and verified by verify_inner_signature in app/e2e_crypto.py. Bit-exact compatibility is mandatory.",
  "vectors": [
    {
      "name": "simple_no_seq",
      "version": 1,
      "input": {
        "session_id": "sess-abc",
        "sender_agent_id": "acme::buyer",
        "nonce": "nonce-001",
        "timestamp": 1700000000,
        "payload": {
          "action": "rfq",
          "amount": 1000
        },
        "client_seq": null
      },
      "expected_canonical_b64": "c2Vzcy1hYmN8YWNtZTo6YnV5ZXJ8bm9uY2UtMDAxfDE3MDAwMDAwMDB8eyJhY3Rpb24iOiJyZnEiLCJhbW91bnQiOjEwMDB9",
      "expected_canonical_string": "sess-abc|acme::buyer|nonce-001|1700000000|{\"action\":\"rfq\",\"amount\":1000}",
      "notes": "Format: session_id|sender|nonce|timestamp[|client_seq]|canonical_json(payload)."
    },
    {
      "name": "with_client_seq",
      "version": 1,
      "input": {
        "session_id": "sess-abc",
        "sender_agent_id": "acme::buyer",
        "nonce": "nonce-002",
        "timestamp": 1700000001,
        "payload": {
          "action": "accept",
          "ref": "RFQ-9"
        },
        "client_seq": 7
      },
      "expected_canonical_b64": "c2Vzcy1hYmN8YWNtZTo6YnV5ZXJ8bm9uY2UtMDAyfDE3MDAwMDAwMDF8N3x7ImFjdGlvbiI6ImFjY2VwdCIsInJlZiI6IlJGUS05In0",
      "expected_canonical_string": "sess-abc|acme::buyer|nonce-002|1700000001|7|{\"action\":\"accept\",\"ref\":\"RFQ-9\"}",
      "notes": "Format: session_id|sender|nonce|timestamp[|client_seq]|canonical_json(payload)."
    },
    {
      "name": "nested_payload",
      "version": 1,
      "input": {
        "session_id": "sess-XYZ",
        "sender_agent_id": "supplier::main",
        "nonce": "n3",
        "timestamp": 1700000999,
        "payload": {
          "items": [
            {
              "sku": "A",
              "qty": 5
            },
            {
              "sku": "B",
              "qty": 2
            }
          ],
          "delivery": {
            "city": "Milano",
            "iso2": "IT"
          }
        },
        "client_seq": 1
      },
      "expected_canonical_b64": "c2Vzcy1YWVp8c3VwcGxpZXI6Om1haW58bjN8MTcwMDAwMDk5OXwxfHsiZGVsaXZlcnkiOnsiY2l0eSI6Ik1pbGFubyIsImlzbzIiOiJJVCJ9LCJpdGVtcyI6W3sicXR5Ijo1LCJza3UiOiJBIn0seyJxdHkiOjIsInNrdSI6IkIifV19",
      "expected_canonical_string": "sess-XYZ|supplier::main|n3|1700000999|1|{\"delivery\":{\"city\":\"Milano\",\"iso2\":\"IT\"},\"items\":[{\"qty\":5,\"sku\":\"A\"},{\"qty\":2,\"sku\":\"B\"}]}",
      "notes": "Format: session_id|sender|nonce|timestamp[|client_seq]|canonical_json(payload)."
    }
  ]
}
