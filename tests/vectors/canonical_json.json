{
  "$schema": "cullis-test-vectors-v1",
  "primitive": "canonical_json",
  "warning": "DO NOT USE THESE KEYS IN PRODUCTION \u2014 test vectors only",
  "header": "Canonical JSON used by Cullis everywhere a dict needs a deterministic byte serialization (signed payloads, JWK thumbprints, audit hashes). Format: sort_keys=True, separators=(',', ':'), ensure_ascii=True.",
  "vectors": [
    {
      "name": "empty_object",
      "version": 1,
      "input": {},
      "expected_bytes_b64": "e30",
      "expected_string": "{}",
      "notes": "Empty dict canonicalizes to '{}'."
    },
    {
      "name": "simple_flat",
      "version": 1,
      "input": {
        "b": 2,
        "a": 1,
        "c": "hello"
      },
      "expected_bytes_b64": "eyJhIjoxLCJiIjoyLCJjIjoiaGVsbG8ifQ",
      "expected_string": "{\"a\":1,\"b\":2,\"c\":\"hello\"}",
      "notes": "Sorted keys: a, b, c."
    },
    {
      "name": "nested",
      "version": 1,
      "input": {
        "outer": {
          "z": [
            1,
            2,
            3
          ],
          "a": true
        },
        "name": "\u00fcn\u00efc\u00f8de",
        "n": null
      },
      "expected_bytes_b64": "eyJuIjpudWxsLCJuYW1lIjoiXHUwMGZjblx1MDBlZmNcdTAwZjhkZSIsIm91dGVyIjp7ImEiOnRydWUsInoiOlsxLDIsM119fQ",
      "expected_string": "{\"n\":null,\"name\":\"\\u00fcn\\u00efc\\u00f8de\",\"outer\":{\"a\":true,\"z\":[1,2,3]}}",
      "notes": "ensure_ascii=True escapes non-ASCII characters."
    },
    {
      "name": "numbers_and_bools",
      "version": 1,
      "input": {
        "int": 42,
        "float": 3.14,
        "neg": -7,
        "bool": false
      },
      "expected_bytes_b64": "eyJib29sIjpmYWxzZSwiZmxvYXQiOjMuMTQsImludCI6NDIsIm5lZyI6LTd9",
      "expected_string": "{\"bool\":false,\"float\":3.14,\"int\":42,\"neg\":-7}",
      "notes": "Numbers serialised the json-stdlib way."
    }
  ]
}
