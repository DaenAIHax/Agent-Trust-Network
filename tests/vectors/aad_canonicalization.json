{
  "$schema": "cullis-test-vectors-v1",
  "primitive": "aad_canonicalization",
  "warning": "DO NOT USE THESE KEYS IN PRODUCTION \u2014 test vectors only",
  "header": "AES-GCM AAD canonicalization used in app/e2e_crypto.py. Binds the ciphertext to the session and the sender, plus an optional per-client monotonic sequence number.",
  "vectors": [
    {
      "name": "no_client_seq",
      "version": 1,
      "input": {
        "session_id": "sess-abc-123",
        "sender_agent_id": "acme::buyer",
        "client_seq": null
      },
      "expected_aad_b64": "c2Vzcy1hYmMtMTIzfGFjbWU6OmJ1eWVy",
      "expected_aad_string": "sess-abc-123|acme::buyer",
      "notes": "AAD format: session_id|sender_agent_id[|client_seq]."
    },
    {
      "name": "with_client_seq",
      "version": 1,
      "input": {
        "session_id": "sess-abc-123",
        "sender_agent_id": "acme::buyer",
        "client_seq": 42
      },
      "expected_aad_b64": "c2Vzcy1hYmMtMTIzfGFjbWU6OmJ1eWVyfDQy",
      "expected_aad_string": "sess-abc-123|acme::buyer|42",
      "notes": "AAD format: session_id|sender_agent_id[|client_seq]."
    },
    {
      "name": "spiffe_id_sender",
      "version": 1,
      "input": {
        "session_id": "sess-XYZ",
        "sender_agent_id": "spiffe://acme.example/agent/buyer",
        "client_seq": 0
      },
      "expected_aad_b64": "c2Vzcy1YWVp8c3BpZmZlOi8vYWNtZS5leGFtcGxlL2FnZW50L2J1eWVyfDA",
      "expected_aad_string": "sess-XYZ|spiffe://acme.example/agent/buyer|0",
      "notes": "AAD format: session_id|sender_agent_id[|client_seq]."
    }
  ]
}
